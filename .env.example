# Meta Messenger
VERIFY_TOKEN=replace_with_a_long_random_secret
PAGE_ACCESS_TOKEN=
GRAPH_API_VERSION=v24.0

# Email over HTTPS (recommended for Render Free)
RESEND_API_KEY=replace_with_resend_api_key
RESEND_FROM=Messenger Bot <onboarding@resend.dev>
NOTIFY_EMAIL=your-email@gmail.com

# WhatsApp Cloud API notifications
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TO=966596312709
# Keep the built-in template for initial testing. After Meta approves your
# custom template, set its lowercase API name and language code here.
WHATSAPP_TEMPLATE_NAME=hello_world
WHATSAPP_TEMPLATE_LANGUAGE=en_US

# Optional SMTP fallback (paid Render or local use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=replace_with_google_app_password

# Application
GIN_MODE=release
PORT=8080

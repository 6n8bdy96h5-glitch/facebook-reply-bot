# Meta Messenger
VERIFY_TOKEN=replace_with_a_long_random_secret
PAGE_ACCESS_TOKEN=
GRAPH_API_VERSION=v24.0

# Email over HTTPS (recommended for Render Free)
RESEND_API_KEY=replace_with_resend_api_key
RESEND_FROM=Messenger Bot <onboarding@resend.dev>
NOTIFY_EMAIL=your-email@gmail.com

# Optional SMTP fallback (paid Render or local use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=replace_with_google_app_password

# Optional AI replies
OPENAI_API_KEY=

# Application
GIN_MODE=release
PORT=8080
